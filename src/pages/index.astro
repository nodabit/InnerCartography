---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inner Cartography">
	<div class="w-full min-h-screen flex items-center justify-center bg-white p-8 pr-24">
		<!-- 메인 일러스트레이터 / Null 텍스트 영역 -->
		<div class="max-w-4xl w-full flex flex-col items-center justify-center text-center space-y-12">
			
			<div class="w-1/2 max-w-[336px] flex items-center justify-center relative group">
				<img 
					src="/assets/images/main-visual.png" 
					alt="Main Illustration" 
					class="w-full h-auto object-contain transition-transform duration-700 group-hover:scale-105"
					onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
				/>
				<!-- Fallback placeholder if image not found -->
				<div class="absolute inset-0 bg-gradient-to-tr from-brand-700 to-brand-500 opacity-20 flex items-center justify-center hidden">
					<span class="text-white text-xs font-light tracking-widest uppercase text-center p-8 border border-white/20">Add main-visual.png</span>
				</div>
			</div>
			
			<div class="space-y-3">
				<h1 class="text-[50px] text-neutral-400 font-aqua font-normal opacity-100 uppercase tracking-widest">
					Inner Cartography
				</h1>
				<p class="text-brand-800 max-w-xl mx-auto leading-relaxed text-[20px] font-roboto-slab font-normal uppercase opacity-100 tracking-[0.2em]">
					An Atlas of the Mind
				</p>
			</div>
			
		</div>
	</div>
</Layout>
