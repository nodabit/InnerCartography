---
import Layout from '../../layouts/Layout.astro';
import { sanityClient } from "sanity:client";
import { PortableText } from "astro-portabletext";
import imageUrlBuilder from '@sanity/image-url';

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`*[_type == "post"] | order(publishedAt desc) {
    "slug": slug.current
  }`);

  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;

// Fetch current post and its neighbors
const query = `*[_type == "post" && slug.current == $slug][0] {
  title,
  classification,
  publishedAt,
  excerpt,
  "mainImage": mainImage.asset->url,
  body,
  "category": category->title,
  "prev": *[_type == "post" && category->title == ^.category->title && publishedAt < ^.publishedAt] | order(publishedAt desc)[0] {
    title,
    "slug": slug.current
  },
  "next": *[_type == "post" && category->title == ^.category->title && publishedAt > ^.publishedAt] | order(publishedAt asc)[0] {
    title,
    "slug": slug.current
  }
}`;

const post = await sanityClient.fetch(query, { slug });

if (!post) {
  return Astro.redirect(`${base}404/`);
}

const builder = imageUrlBuilder(sanityClient);
function urlFor(source) {
  return builder.image(source);
}

const formattedDate = new Date(post.publishedAt)
  .toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' })
  .replace(/. /g, '.')
  .replace('.', '');

const base = import.meta.env.BASE_URL;
---

<Layout title={post.title}>
  <div class="w-full min-h-screen bg-white pb-32">
    <!-- Post Header -->
    <header class="w-full pt-32 pb-16 px-8 flex flex-col items-center text-center max-w-4xl mx-auto">
      <div class="flex items-center gap-3 mb-6">
         <span class="text-[10px] text-neutral-300 font-aqua tracking-[0.4em] uppercase">
          {formattedDate}
        </span>
        <span class="w-1 h-1 rounded-full bg-neutral-200"></span>
        <span class="text-[12px] text-brand-800 font-nanumsquare font-bold tracking-widest uppercase">
          {post.category}
        </span>
      </div>

      <h1 class="text-3xl md:text-5xl text-neutral-600 font-nanumsquare font-light leading-tight mb-8 tracking-tight uppercase">
        {post.classification && <span class="text-brand-700 mr-2">[{post.classification}]</span>}
        {post.title}
      </h1>

      {post.excerpt && (
        <p class="text-lg text-neutral-400 font-nanumsquare font-light leading-relaxed max-w-2xl opacity-80 italic">
          {post.excerpt}
        </p>
      )}
    </header>

    <!-- Main Visual Image -->
    {post.mainImage && (
      <div class="w-full max-w-6xl mx-auto px-8 mb-20">
        <div class="aspect-[21/9] overflow-hidden grayscale-[0.2] hover:grayscale-0 transition-all duration-1000">
          <img 
            src={post.mainImage} 
            alt={post.title} 
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    )}

    <!-- Post Body -->
    <article class="prose prose-neutral prose-lg mx-auto px-8 font-nanumsquare text-neutral-500 leading-loose
      prose-headings:font-nanumsquare prose-headings:font-normal prose-headings:text-neutral-600
      prose-p:opacity-90 prose-p:mb-8
      prose-img:rounded-none prose-img:shadow-sm
      prose-a:text-brand-800 prose-a:no-underline hover:prose-a:underline
      max-w-3xl">
      <PortableText value={post.body} />
    </article>

    <!-- Post Footer: Prev / Next -->
    <footer class="max-w-3xl mx-auto px-8 mt-32 pt-12 border-t border-neutral-100">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Previous Post -->
        <div class="flex flex-col items-start text-left">
          <span class="text-[10px] text-neutral-300 font-aqua tracking-widest uppercase mb-4">Previous Post</span>
          {post.prev ? (
            <a href={`${base}posts/${post.prev.slug}/`} class="group">
              <span class="text-base text-neutral-500 font-nanumsquare group-hover:text-brand-900 transition-colors line-clamp-2">
                {post.prev.title}
              </span>
            </a>
          ) : (
            <span class="text-sm text-neutral-200 font-nanumsquare italic">No earlier memories</span>
          )}
        </div>

        <!-- Next Post -->
        <div class="flex flex-col items-end text-right">
          <span class="text-[10px] text-neutral-300 font-aqua tracking-widest uppercase mb-4">Next Post</span>
          {post.next ? (
            <a href={`${base}posts/${post.next.slug}/`} class="group">
              <span class="text-base text-neutral-500 font-nanumsquare group-hover:text-brand-900 transition-colors line-clamp-2 text-right">
                {post.next.title}
              </span>
            </a>
          ) : (
            <span class="text-sm text-neutral-200 font-nanumsquare italic">The atlas ends here</span>
          )}
        </div>
      </div>

      <!-- Back to List -->
      <div class="mt-20 flex justify-center">
        <a 
          href={`${base}${post.category.toLowerCase()}/`} 
          class="inline-block px-10 py-3 border border-neutral-100 text-[11px] font-aqua tracking-[0.3em] text-neutral-400 uppercase hover:border-brand-300 hover:text-brand-900 transition-all"
        >
          Back to Index
        </a>
      </div>
    </footer>
  </div>
</Layout>

<style is:global>
  /* Portable Text custom styles */
  .prose img {
    margin-top: 3rem;
    margin-bottom: 3rem;
    width: 100%;
  }
  .prose p {
    margin-bottom: 2rem;
  }
</style>
