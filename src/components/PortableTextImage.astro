---
import imageUrlBuilder from '@sanity/image-url';
import { sanityClient } from "sanity:client";

const { node } = Astro.props;
const builder = imageUrlBuilder(sanityClient);
const url = node.asset ? builder.image(node).url() : null;
---

{url && (
  <div class="my-12 lg:my-20 flex flex-col items-center w-full">
    <img 
      src={url} 
      alt={node.alt || ''} 
      class="max-w-full md:max-w-[70%] h-auto shadow-sm rounded-sm hover:scale-[1.01] transition-transform duration-500"
    />
    {node.caption && (
      <p class="text-[11px] text-neutral-400 mt-4 lg:mt-6 italic font-light font-nanumsquare max-w-xl text-center px-4 leading-relaxed">
        {node.caption}
      </p>
    )}
  </div>
)}
